{
  "name": "webdav-to-s3",
  "version": "0.1.0",
  "description": "Multi-tenant S3-compatible gateway backed by WebDAV upstreams.",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "s3",
    "webdav",
    "gateway",
    "proxy"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "fast-xml-parser": "4.5.3",
    "fastify": "5.6.2",
    "undici": "7.16.0",
    "zod": "4.1.5"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@types/node": "24.3.0",
    "tsx": "4.20.5",
    "typescript": "5.9.2",
    "vitest": "3.2.4"
  }
}
